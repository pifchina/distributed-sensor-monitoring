{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=sensordb;Username=snus;Password=snus"
  },
  "FaultTolerance": {
    "InactivityTimeoutSeconds": 10
  },
  "Security": {
    "ServerPrivateKeyPath": "../../keys/server/server_rsa_private.pem",
    "SensorPublicKeysDirectory": "../../keys/server/sensors",
    "TimestampToleranceSeconds": 30
  },
  "NotificationService": {
    "BaseUrl": "http://localhost:5003"
  },
  "RateLimiting": {
    "PermitLimit": 10,
    "WindowSeconds": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
